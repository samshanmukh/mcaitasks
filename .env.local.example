# Anthropic API Key — get yours at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-...

# McClaw agent wallet private key (0x...)
MCCLAW_PRIVATE_KEY=0x_your_wallet_private_key_here

# McClaw API key — received after running: node mcclaw-sdk/dist/cli.mjs register
MCCLAW_API_KEY=your_mcclaw_api_key_after_registration

# Base network RPC endpoint
MCCLAW_RPC_URL=https://mainnet.base.org

# McClaw API base URL
MCCLAW_API_URL=https://mcclaw.io/api/v1
